
# Use host.docker.internal to connect from container to your local Postgres instance
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:80
ConnectionStrings__DefaultConnection=Host=host.docker.internal;Port=5432;Database=microloan_notification_db;Username=postgres;Password=123456

# RabbitMQ credentials for the dockerized RabbitMQ service
RABBITMQ__HOSTNAME=rabbitmq
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest

